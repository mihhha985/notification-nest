# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Producer HTTP ---
PRODUCER_PORT=3000
PORT=3000

# --- RabbitMQ (клиентские сервисы) ---
# Для Docker Compose host переопределяется на "rabbitmq" в docker-compose.yml
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

RABBITMQ_EXCHANGE=notifications
RABBITMQ_ROUTING_KEY=telegram.notify
RABBITMQ_QUEUE=telegram.notifications

# --- Producer ---
RABBITMQ_CONNECT_RETRY_ATTEMPTS=5
RABBITMQ_PUBLISH_RETRY_ATTEMPTS=3

# --- Consumer ---
RABBITMQ_PREFETCH=1
RABBITMQ_AUTO_ACK=false
RABBITMQ_MAX_RETRIES=3
TELEGRAM_SEND_RETRY_ATTEMPTS=3
IDEMPOTENCY_CACHE_SIZE=10000

# --- RabbitMQ container (docker-compose) ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_DEFAULT_VHOST=/
